# Variables de entorno

# (Opcional) Para usar Google Cloud Vision API con mejor reconocimiento de texto a mano
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
# Habilita "Cloud Vision API" en tu proyecto de Google Cloud
NEXT_PUBLIC_GOOGLE_VISION_API_KEY=

# Sin esta key, la app usará Tesseract.js (local, sin costo)
# Con esta key, se activará Google Vision para mejor reconocimiento de escritura a mano
